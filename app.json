{
  "expo": {
    "name": "Splish",
    "slug": "splish-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "splishapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.splish.app",
      "entitlements": {
        "com.apple.security.application-groups": ["group.io.splish.app"]
      },
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Splish uses notifications to remind you to drink water throughout the day.",
        "NSHealthShareUsageDescription": "Splish can optionally log your water intake to Apple Health.",
        "NSCameraUsageDescription": "Splish uses your camera to verify you've drunk water in Hard Mode."
      }
    },
    "android": {
      "package": "com.splish.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-video",
      "expo-camera",
      "expo-notifications",
      "./plugins/with-android-widget",
      "./plugins/with-ios-app-groups",
      "./plugins/with-hard-mode"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
